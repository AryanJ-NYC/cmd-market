generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SellerEligibilityStatus {
  pending
  eligible
  revoked
  suspended
}

enum SellerEligibilitySource {
  manual_override
  x_verification
}

enum ListingStatus {
  draft
  published
  reserved
  sold
  cancelled
  expired
}

enum AttributeValueType {
  text
  number
  boolean
  enum
  json
}

model user {
  id              String       @id @default(cuid())
  name            String
  email           String       @unique
  emailVerified   Boolean      @default(false)
  image           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  accounts        account[]
  auditEvents     auditEvent[] @relation("auditEventActorUser")
  createdListings listing[]    @relation("listingCreatedByUser")
  invitationsSent invitation[] @relation("invitationInviter")
  members         member[]
  sessions        session[]
  updatedListings listing[]    @relation("listingUpdatedByUser")

  @@map("user")
}

model session {
  id                   String        @id @default(cuid())
  expiresAt            DateTime
  token                String        @unique
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?
  activeOrganization   organization? @relation("activeOrganizationSessions", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  user                 user          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model organization {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  logo           String?
  createdAt      DateTime       @default(now())
  metadata       String?
  activeSessions session[]      @relation("activeOrganizationSessions")
  apiKeys        apikey[]       @relation("organizationApiKeys")
  invitations    invitation[]
  members        member[]
  sellerAccount  sellerAccount?

  @@map("organization")
}

model member {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           user         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  inviter        user         @relation("invitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model apikey {
  id                  String       @id @default(cuid())
  configId            String       @default("default")
  name                String?
  start               String?
  referenceId         String
  prefix              String?
  key                 String       @unique
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean      @default(true)
  rateLimitEnabled    Boolean      @default(true)
  rateLimitTimeWindow Int          @default(86400000)
  rateLimitMax        Int          @default(10)
  requestCount        Int          @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  permissions         String?
  metadata            String?
  auditEvents         auditEvent[] @relation("auditEventActorApiKey")
  createdListings     listing[]    @relation("listingCreatedByApiKey")
  organization        organization @relation("organizationApiKeys", fields: [referenceId], references: [id], onDelete: Cascade)
  updatedListings     listing[]    @relation("listingUpdatedByApiKey")

  @@index([configId])
  @@index([referenceId])
  @@unique([configId, referenceId])
  @@map("apikey")
}

model sellerAccount {
  id                         String       @id
  organizationId             String       @unique @map("organization_id")
  status                     String
  listingEligibilityStatus   SellerEligibilityStatus @map("listing_eligibility_status")
  listingEligibilitySource   SellerEligibilitySource? @map("listing_eligibility_source")
  listingEligibilityNote     String?      @map("listing_eligibility_note")
  defaultDisplayCurrencyCode String       @default("USD") @map("default_display_currency_code")
  createdAt                  DateTime     @default(now()) @map("created_at")
  updatedAt                  DateTime     @updatedAt @map("updated_at")
  auditEvents                auditEvent[]
  listings                   listing[]
  organization               organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("seller_account")
}

model category {
  id                String              @id
  slug              String              @unique
  name              String
  description       String?
  sortOrder         Int                 @default(0) @map("sort_order")
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  categoryAttributes categoryAttribute[]
  listings          listing[]

  @@map("category")
}

model attributeDefinition {
  id               String              @id
  key              String              @unique
  label            String
  valueType        AttributeValueType  @map("value_type")
  unitLabel        String?             @map("unit_label")
  configurationJson Json?              @map("configuration_json")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  categoryAttributes categoryAttribute[]

  @@map("attribute_definition")
}

model categoryAttribute {
  id                   String               @id
  categoryId           String               @map("category_id")
  attributeDefinitionId String              @map("attribute_definition_id")
  isRequired           Boolean              @default(false) @map("is_required")
  isFilterable         Boolean              @default(false) @map("is_filterable")
  isSortable           Boolean              @default(false) @map("is_sortable")
  sortOrder            Int                  @default(0) @map("sort_order")
  allowedValuesJson    Json?                @map("allowed_values_json")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  attributeDefinition  attributeDefinition  @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)
  category             category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  listingAttributeValues listingAttributeValue[]

  @@unique([categoryId, attributeDefinitionId])
  @@map("category_attribute")
}

model auditEvent {
  id              String         @id
  entityTable     String         @map("entity_table")
  entityId        String         @map("entity_id")
  action          String
  actorType       String         @map("actor_type")
  actorUserId     String?        @map("actor_user_id")
  actorApiKeyId   String?        @map("actor_api_key_id")
  sellerAccountId String?        @map("seller_account_id")
  note            String?
  metadata        Json
  createdAt       DateTime       @default(now()) @map("created_at")
  actorApiKey     apikey?        @relation("auditEventActorApiKey", fields: [actorApiKeyId], references: [id], onDelete: SetNull)
  actorUser       user?          @relation("auditEventActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  sellerAccount   sellerAccount? @relation(fields: [sellerAccountId], references: [id], onDelete: SetNull)

  @@index([sellerAccountId])
  @@map("audit_event")
}

model listing {
  id                 String                 @id
  sellerAccountId    String                 @map("seller_account_id")
  categoryId         String?                @map("category_id")
  title              String?
  description        String?
  conditionCode      String?                @map("condition_code")
  quantityAvailable  Int?                   @map("quantity_available")
  unitPriceMinor     Int?                   @map("unit_price_minor")
  displayCurrencyCode String                @default("USD") @map("display_currency_code")
  status             ListingStatus          @default(draft)
  publishedAt        DateTime?              @map("published_at")
  closedAt           DateTime?              @map("closed_at")
  createdByUserId    String?                @map("created_by_user_id")
  createdByApiKeyId  String?                @map("created_by_api_key_id")
  updatedByUserId    String?                @map("updated_by_user_id")
  updatedByApiKeyId  String?                @map("updated_by_api_key_id")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  attributeValues    listingAttributeValue[]
  category           category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByApiKey    apikey?                @relation("listingCreatedByApiKey", fields: [createdByApiKeyId], references: [id], onDelete: SetNull)
  createdByUser      user?                  @relation("listingCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  media              listingMedia[]
  sellerAccount      sellerAccount          @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  updatedByApiKey    apikey?                @relation("listingUpdatedByApiKey", fields: [updatedByApiKeyId], references: [id], onDelete: SetNull)
  updatedByUser      user?                  @relation("listingUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([sellerAccountId])
  @@index([categoryId])
  @@map("listing")
}

model listingMedia {
  id         String   @id
  listingId  String   @map("listing_id")
  assetKey   String   @map("asset_key")
  assetType  String   @map("asset_type")
  altText    String?  @map("alt_text")
  sortOrder  Int      @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  listing    listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@unique([listingId, assetKey])
  @@map("listing_media")
}

model listingAttributeValue {
  id                String            @id
  listingId         String            @map("listing_id")
  categoryAttributeId String          @map("category_attribute_id")
  valueText         String?           @map("value_text")
  valueNumber       Float?            @map("value_number")
  valueBoolean      Boolean?          @map("value_boolean")
  valueJson         Json?             @map("value_json")
  normalizedText    String?           @map("normalized_text")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  categoryAttribute categoryAttribute @relation(fields: [categoryAttributeId], references: [id], onDelete: Cascade)
  listing           listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([categoryAttributeId])
  @@unique([listingId, categoryAttributeId])
  @@map("listing_attribute_value")
}
