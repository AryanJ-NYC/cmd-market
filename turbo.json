{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "BETTER_AUTH_SECRET",
    "DEV_SELLER_OVERRIDE_EMAILS",
    "DO_SPACES_ACCESS_KEY_ID",
    "DO_SPACES_SECRET_ACCESS_KEY",
    "NEON_DATABASE_URL",
    "NEON_DATABASE_URL_UNPOOLED",
    "X_CLIENT_ID",
    "X_CLIENT_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
